{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v2/crates/tauri-config-schema/schema.json",
  "productName": "koompi-orch",
  "identifier": "com.koompi.orch",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "koompi-orch",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "plugins": {
    "notification": {
      "enabled": true
    },
    "shell": {
      "open": true
    }
  }
}
