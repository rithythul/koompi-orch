{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v2/crates/tauri-config-schema/schema.json",
  "productName": "koompi-orch",
  "version": "0.0.1",
  "identifier": "com.koompi.orch",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "AI agent orchestrator",
    "longDescription": "Desktop application for orchestrating multiple AI coding agents in parallel."
  },
  "app": {
    "windows": [
      {
        "title": "koompi-orch",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "plugins": {
    "notification": {
      "enabled": true
    },
    "shell": {
      "open": true
    }
  }
}
